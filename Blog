
<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<title>Mukesh Blog</title>
<style>
body{margin:0;font-family:Arial,sans-serif;background:#0f172a;color:#fff}
header{padding:60px 20px;text-align:center;background:linear-gradient(135deg,#0ea5e9,#1e293b)}
h1{margin:0;font-size:42px}.sub{max-width:700px;margin:15px auto;color:#d1d5db}
#search{width:min(500px,90%);padding:12px;border-radius:8px;border:none}
.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:20px;padding:40px;max-width:1200px;margin:auto}
.card{background:#1e293b;border-radius:12px;overflow:hidden;transition:.3s}
.card:hover{transform:translateY(-5px)}
.card img{width:100%;height:180px;object-fit:cover}
.content{padding:18px}.tag{display:inline-block;background:#0284c7;padding:4px 10px;border-radius:20px;font-size:12px}
a.btn{display:inline-block;margin-top:12px;color:#38bdf8;text-decoration:none}
footer{text-align:center;padding:25px;color:#94a3b8}
</style></head><body>
<header><h1>DevOps & Full Stack Blog</h1><p class="sub">Tutorials on AWS, Docker, Kubernetes, React, Next.js, JavaScript and Career Tips.</p><input id="search" placeholder="Search blog..."></header>
<section class="grid" id="grid"></section>
<footer>© 2026 Mukesh Portfolio Blog</footer>
<script>
const blogs=[
["Complete Docker Tutorial","DevOps","https://picsum.photos/600/400?1"],
["AWS Beginner Guide","Cloud","https://picsum.photos/600/400?2"],
["Learn Kubernetes","Kubernetes","https://picsum.photos/600/400?3"],
["React vs Next.js","React","https://picsum.photos/600/400?4"],
["Git & GitHub Guide","Git","https://picsum.photos/600/400?5"],
["Top DevOps Tools","Career","https://picsum.photos/600/400?6"],
["Node.js REST API","Backend","https://picsum.photos/600/400?7"],
["Linux Commands","Linux","https://picsum.photos/600/400?8"],
["CI/CD with Jenkins","DevOps","https://picsum.photos/600/400?9"],
["Business Analysis Basics","BA","https://picsum.photos/600/400?10"]
];
const grid=document.getElementById('grid');
function render(list){
grid.innerHTML='';
list.forEach(b=>{
grid.innerHTML+=`<div class='card'><img src='${b[2]}'><div class='content'><span class='tag'>${b[1]}</span><h3>${b[0]}</h3><p>Practical guide with real-world examples and best practices.</p><a class='btn' href='#'>Read More →</a></div></div>`;
});
}
render(blogs);
search.oninput=e=>{
const q=e.target.value.toLowerCase();
render(blogs.filter(b=>b[0].toLowerCase().includes(q)||b[1].toLowerCase().includes(q)));
}
</script></body></html>
